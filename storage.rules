rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Payment receipts — only uploader and admins
    match /payment-receipts/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Platform assets (avatars, materials) — authenticated users read, admins/instructors write
    match /platform-assets/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Message attachments — authenticated users
    match /message-attachments/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
